{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://observability.xceedance.internal/schemas/profile-sample.schema.json",
  "title": "Continuous Profile Sample",
  "description": "Canonical envelope for a continuous-profiling sample emitted to Pyroscope (or any pprof-compatible backend). Aligned with the pprof profile format and the OpenTelemetry profiling signal (development). Samples are aggregated server-side by stack-trace identity; raw stacks are not persisted beyond the configured retention window.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile_id",
    "profile_type",
    "start_time_unix_nano",
    "duration_nano",
    "resource",
    "samples"
  ],
  "properties": {
    "profile_id": {
      "type": "string",
      "format": "uuid",
      "description": "UUIDv4 identifying the profile window."
    },
    "profile_type": {
      "type": "string",
      "enum": ["cpu", "wall", "alloc_objects", "alloc_space", "inuse_objects", "inuse_space", "goroutines", "mutex", "block"],
      "description": "pprof-aligned profile kind."
    },
    "start_time_unix_nano": { "type": "integer", "minimum": 1577836800000000000 },
    "duration_nano": {
      "type": "integer",
      "minimum": 1000000,
      "maximum": 3600000000000,
      "description": "Profile window length, 1 ms to 1 hour. Production default is 15 s."
    },
    "sample_rate_hz": {
      "type": "integer",
      "minimum": 1,
      "maximum": 1000,
      "description": "Sampling frequency. CPU profiles default 100 Hz."
    },
    "resource": { "$ref": "metric-sample.schema.json#/$defs/resource" },
    "labels": {
      "type": "object",
      "description": "Bounded-cardinality labels for slicing profiles (e.g. by transaction.name).",
      "maxProperties": 16,
      "additionalProperties": { "type": ["string", "number", "boolean"] },
      "properties": {
        "transaction.name": { "type": "string", "maxLength": 64 },
        "journey.name":     { "type": "string", "maxLength": 64 },
        "tenant_class":     { "type": "string", "enum": ["t1", "t2", "t3", "internal"] }
      }
    },
    "samples": {
      "type": "array",
      "minItems": 1,
      "description": "Aggregated stack-trace samples in the profile window.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["stack_id", "values"],
        "properties": {
          "stack_id": {
            "type": "string",
            "pattern": "^[0-9a-f]{16,64}$",
            "description": "Stable hash of the (function_id, line) tuple sequence; used for server-side aggregation."
          },
          "values": {
            "type": "array",
            "description": "Aligned with the profile_type. For cpu profiles, [cpu_nanoseconds, sample_count].",
            "items": { "type": "integer", "minimum": 0 },
            "minItems": 1,
            "maxItems": 4
          }
        }
      }
    },
    "function_table": {
      "type": "array",
      "description": "Symbolised function dictionary referenced by stack samples. Omitted when the backend performs symbolication.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["function_id", "name"],
        "properties": {
          "function_id":  { "type": "integer", "minimum": 1 },
          "name":         { "type": "string", "maxLength": 512 },
          "system_name":  { "type": "string", "maxLength": 512 },
          "filename":     { "type": "string", "maxLength": 512 },
          "start_line":   { "type": "integer", "minimum": 0 }
        }
      }
    }
  }
}
